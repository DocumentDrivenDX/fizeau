# Benchmark artifacts: only the version-rooted indexes and version marker
# under bench/results are committed; cells/, profiles/, and lane-output dirs
# stay local. Pattern matches fiz-tools-v* (canonical) and the legacy fiz-v*
# variant.
/bench/results/
!/bench/results/
/bench/results/*
!/bench/results/fiz-tools-v*/
/bench/results/fiz-tools-v*/**
!/bench/results/fiz-tools-v*/.fiz-benchmark-version.json
!/bench/results/fiz-tools-v*/indexes/
!/bench/results/fiz-tools-v*/indexes/**
# Legacy pre-consolidation output root; keep ignored if it exists in an older
# worktree.
/benchmark-results/
/jobs/

# Local root build artifacts
/fiz
/bench-fixed
.venv-report

