{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://easel.github.io/fizeau/schemas/benchmark-cells.schema.json",
  "title": "Fizeau benchmark cells datatable feed",
  "type": "object",
  "required": ["schema_version", "generated_at", "source", "rows"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "required": ["cells_root", "profiles_dir", "machines_file", "suites", "n_reports", "n_rows", "n_excluded"],
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean", "null", "array", "object"]
      },
      "properties": {
        "cells_root": { "type": "string" },
        "profiles_dir": { "type": "string" },
        "machines_file": { "type": "string" },
        "suites": {
          "type": "array",
          "items": { "type": "string" }
        },
        "n_reports": { "type": "integer", "minimum": 0 },
        "n_rows": { "type": "integer", "minimum": 0 },
        "n_excluded": { "type": "integer", "minimum": 0 },
        "result_state_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "excluded_result_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "excluded_invalid_classes": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "excluded_final_statuses": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "excluded_process_outcomes": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "excluded_grading_outcomes": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/cell" }
    }
  },
  "$defs": {
    "nullableString": {
      "type": ["string", "null"]
    },
    "nullableNumber": {
      "type": ["number", "null"]
    },
    "nullableInteger": {
      "type": ["integer", "null"]
    },
    "nullableBoolean": {
      "type": ["boolean", "null"]
    },
    "cell": {
      "type": "object",
      "required": [
        "row_id",
        "schema_version",
        "source_report",
        "suite",
        "task",
        "internal_lane_id",
        "profile_id",
        "profile_exists",
        "lane_label",
        "descriptor",
        "rep",
        "result_state",
        "final_status",
        "passed"
      ],
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean", "null", "array", "object"]
      },
      "properties": {
        "row_id": { "type": "string" },
        "schema_version": { "type": "integer", "const": 1 },
        "source_report": { "type": "string" },
        "suite": { "type": "string" },
        "task": { "type": "string" },
        "task_subsets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "harness": { "$ref": "#/$defs/nullableString" },
        "harness_label": { "$ref": "#/$defs/nullableString" },
        "internal_lane_id": { "type": "string" },
        "profile_id": { "type": "string" },
        "profile_resolved_id": { "$ref": "#/$defs/nullableString" },
        "profile_exists": { "type": "boolean" },
        "profile_path": { "$ref": "#/$defs/nullableString" },
        "lane_label": { "type": "string" },
        "descriptor": { "type": "string" },
        "deployment_class": { "$ref": "#/$defs/nullableString" },

        "provider_type": { "$ref": "#/$defs/nullableString" },
        "provider_surface": { "$ref": "#/$defs/nullableString" },
        "provider_model": { "$ref": "#/$defs/nullableString" },

        "model": { "$ref": "#/$defs/nullableString" },
        "model_id": { "$ref": "#/$defs/nullableString" },
        "model_display_name": { "$ref": "#/$defs/nullableString" },
        "model_family": { "$ref": "#/$defs/nullableString" },
        "profile_snapshot": { "$ref": "#/$defs/nullableString" },
        "quant_display": { "$ref": "#/$defs/nullableString" },
        "model_quant": { "$ref": "#/$defs/nullableString" },
        "weight_bits": { "$ref": "#/$defs/nullableNumber" },
        "kv_cache_quant": { "$ref": "#/$defs/nullableString" },
        "k_quant": { "$ref": "#/$defs/nullableString" },
        "v_quant": { "$ref": "#/$defs/nullableString" },
        "kv_cache_disk": { "$ref": "#/$defs/nullableBoolean" },
        "kv_cache_disk_gb": { "$ref": "#/$defs/nullableNumber" },

        "engine": { "$ref": "#/$defs/nullableString" },
        "engine_version": { "$ref": "#/$defs/nullableString" },
        "backend": { "$ref": "#/$defs/nullableString" },
        "runtime_props_extractor": { "$ref": "#/$defs/nullableString" },
        "runtime_base_model": { "$ref": "#/$defs/nullableString" },
        "runtime_model_quant": { "$ref": "#/$defs/nullableString" },
        "runtime_kv_quant": { "$ref": "#/$defs/nullableString" },
        "runtime_draft_model": { "$ref": "#/$defs/nullableString" },
        "runtime_draft_mode": { "$ref": "#/$defs/nullableString" },
        "runtime_max_context": { "$ref": "#/$defs/nullableInteger" },
        "runtime_mtp_enabled": { "$ref": "#/$defs/nullableBoolean" },

        "machine": { "$ref": "#/$defs/nullableString" },
        "machine_label": { "$ref": "#/$defs/nullableString" },
        "hardware_profile": { "$ref": "#/$defs/nullableString" },
        "hardware_chip": { "$ref": "#/$defs/nullableString" },
        "hardware_chip_family": { "$ref": "#/$defs/nullableString" },
        "gpu_vendor": { "$ref": "#/$defs/nullableString" },
        "gpu_model": { "$ref": "#/$defs/nullableString" },
        "gpu_ram_gb": { "$ref": "#/$defs/nullableNumber" },
        "hardware_vram_gb": { "$ref": "#/$defs/nullableNumber" },
        "hardware_memory_gb": { "$ref": "#/$defs/nullableNumber" },
        "hardware_memory_type": { "$ref": "#/$defs/nullableString" },
        "hardware_tdp_watts": { "$ref": "#/$defs/nullableNumber" },
        "hardware_tdp_source": { "$ref": "#/$defs/nullableString" },
        "hardware_tdp_watts_spec": { "$ref": "#/$defs/nullableNumber" },
        "cpu_model": { "$ref": "#/$defs/nullableString" },
        "os": { "$ref": "#/$defs/nullableString" },

        "rep": { "type": "integer" },
        "result_state": {
          "type": "string",
          "enum": ["passed", "failed", "timeout"]
        },
        "process_outcome": { "$ref": "#/$defs/nullableString" },
        "grading_outcome": { "$ref": "#/$defs/nullableString" },
        "reward": { "$ref": "#/$defs/nullableNumber" },
        "grader_passed": { "$ref": "#/$defs/nullableBoolean" },
        "passed": { "type": "boolean" },
        "pass_fail": {
          "type": "string",
          "enum": ["pass", "fail", "timeout"]
        },
        "final_status": { "type": "string" },
        "invalid_class": { "$ref": "#/$defs/nullableString" },
        "terminated_mid_work": { "$ref": "#/$defs/nullableBoolean" },
        "had_llm_request": { "$ref": "#/$defs/nullableBoolean" },
        "exit_code": { "$ref": "#/$defs/nullableInteger" },

        "turns": { "$ref": "#/$defs/nullableInteger" },
        "tool_calls": { "$ref": "#/$defs/nullableInteger" },
        "tool_call_errors": { "$ref": "#/$defs/nullableInteger" },
        "input_tokens": { "$ref": "#/$defs/nullableInteger" },
        "output_tokens": { "$ref": "#/$defs/nullableInteger" },
        "cached_input_tokens": { "$ref": "#/$defs/nullableInteger" },
        "retried_input_tokens": { "$ref": "#/$defs/nullableInteger" },
        "reasoning_tokens": { "$ref": "#/$defs/nullableInteger" },
        "reasoning_tokens_approx": { "$ref": "#/$defs/nullableBoolean" },
        "total_tokens": { "$ref": "#/$defs/nullableInteger" },
        "wall_seconds": { "$ref": "#/$defs/nullableNumber" },
        "cost_usd": { "$ref": "#/$defs/nullableNumber" },

        "sampling_reasoning": { "$ref": "#/$defs/nullableString" },
        "sampling_temperature": { "$ref": "#/$defs/nullableNumber" },
        "sampling_top_p": { "$ref": "#/$defs/nullableNumber" },
        "sampling_top_k": { "$ref": "#/$defs/nullableNumber" },
        "max_output_tokens": { "$ref": "#/$defs/nullableInteger" },
        "context_tokens": { "$ref": "#/$defs/nullableInteger" },

        "started_at": { "$ref": "#/$defs/nullableString" },
        "finished_at": { "$ref": "#/$defs/nullableString" },
        "fiz_tools_version": { "$ref": "#/$defs/nullableInteger" },
        "dataset": { "$ref": "#/$defs/nullableString" },
        "dataset_version": { "$ref": "#/$defs/nullableString" }
      }
    }
  }
}
