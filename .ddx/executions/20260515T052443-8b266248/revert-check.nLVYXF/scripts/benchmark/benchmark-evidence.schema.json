{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/easel/fizeau/scripts/benchmark/benchmark-evidence.schema.json",
  "title": "Fizeau Benchmark Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "captured_at",
    "source",
    "benchmark",
    "subject",
    "scope",
    "score"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "benchmark-evidence/v1"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["fizeau_runner", "external_leaderboard", "imported_report"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string"
        },
        "artifact_path": {
          "type": "string"
        },
        "artifact_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "benchmark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "examples": ["terminal-bench", "swe-bench", "humaneval", "mmlu", "tau-bench", "beadbench", "mhi"]
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "dataset_commit": {
          "type": "string"
        },
        "dataset": {
          "type": "string"
        },
        "subset_id": {
          "type": "string"
        },
        "subset_version": {
          "type": "string"
        },
        "scorer": {
          "type": "string"
        },
        "scorer_version": {
          "type": "string"
        },
        "higher_is_better": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_raw", "harness", "provider"],
      "properties": {
        "model": {
          "type": "string",
          "description": "Canonical Fizeau catalog model id when known."
        },
        "model_raw": {
          "type": "string",
          "minLength": 1
        },
        "harness": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "endpoint": {
          "type": "string"
        },
        "surface": {
          "type": "string"
        },
        "deployment_class": {
          "type": "string"
        },
        "reasoning": {
          "type": "string"
        },
        "sampling": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "run_id": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        },
        "subset": {
          "type": "string"
        },
        "subset_id": {
          "type": "string"
        },
        "subset_version": {
          "type": "string"
        },
        "denominator_rule": {
          "type": "string"
        },
        "split": {
          "type": "string"
        },
        "rep": {
          "type": "integer",
          "minimum": 1
        },
        "n_tasks": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric", "value"],
      "properties": {
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "number",
          "minimum": 0
        },
        "raw_value": {
          "type": ["number", "string"]
        },
        "n": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "confidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "method": { "type": "string" },
            "lower": { "type": "number" },
            "upper": { "type": "number" }
          }
        }
      }
    },
    "final_status": {
      "type": "string"
    },
    "invalid_class": {
      "type": "string"
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "formula_version": {
          "type": "string"
        },
        "evidence_window": {
          "type": "string"
        },
        "included_benchmarks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "included_subsets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "denominator_rule": {
          "type": "string"
        },
        "coverage_note": {
          "type": "string"
        },
        "confidence_note": {
          "type": "string"
        }
      }
    },
    "denominator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "included": {
          "type": "boolean"
        },
        "policy": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "excluded_classes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excluded_tasks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "included_count": {
          "type": "integer",
          "minimum": 0
        },
        "excluded_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "integer", "string", "boolean", "null", "array", "object"]
      }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "usd": { "type": "number", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": { "type": "integer", "minimum": 0 },
        "pricing_source": { "type": "string" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wall_seconds": { "type": "number", "minimum": 0 },
        "turns": { "type": "integer", "minimum": 0 },
        "tool_calls": { "type": "integer", "minimum": 0 },
        "tool_call_errors": { "type": "integer", "minimum": 0 },
        "exit_code": { "type": "integer" },
        "outcome": { "type": "string" },
        "deployment_class": {
          "type": "string",
          "enum": ["managed_frontier", "managed_non_frontier", "local", "self_hosted"]
        },
        "quantization": {
          "type": "string"
        },
        "local_runtime_name": {
          "type": "string"
        },
        "local_runtime_version": {
          "type": "string"
        },
        "server_name": {
          "type": "string"
        },
        "server_version": {
          "type": "string"
        },
        "context_limit": {
          "type": "integer",
          "minimum": 0
        },
        "hardware_class": {
          "type": "string"
        },
        "hardware_accelerator": {
          "type": "string"
        },
        "hardware_accelerator_backend": {
          "type": "string"
        },
        "hardware_memory_gb": {
          "type": "number",
          "minimum": 0
        },
        "hardware_os": {
          "type": "string"
        },
        "hardware_arch": {
          "type": "string"
        },
        "sampling_temperature": {
          "type": "number"
        },
        "sampling_top_p": {
          "type": "number"
        },
        "sampling_top_k": {
          "type": "integer",
          "minimum": 0
        },
        "sampling_min_p": {
          "type": "number"
        },
        "sampling_reasoning": {
          "type": "string"
        },
        "utilization_active_requests": {
          "type": "integer",
          "minimum": 0
        },
        "utilization_queue_depth": {
          "type": "integer",
          "minimum": 0
        },
        "utilization_memory_pressure": {
          "type": "number",
          "minimum": 0
        },
        "utilization_tokens_per_second": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "integer", "string", "boolean", "null", "array", "object"]
      }
    },
    "runtime_props": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "extractor": {
          "type": "string",
          "description": "Platform name: llamacpp, vllm, ds4, omlx, lucebox, rapid-mlx, openrouter, openai, cloud"
        },
        "extracted_at": {
          "type": "string",
          "format": "date-time"
        },
        "extraction_failed": {
          "type": "string",
          "description": "Reason for extraction failure; only set when extraction was attempted but failed"
        },
        "base_model": {
          "type": "string"
        },
        "model_quant": {
          "type": "string"
        },
        "kv_quant": {
          "type": "string"
        },
        "draft_model": {
          "type": "string"
        },
        "draft_mode": {
          "type": "string",
          "description": "e.g. mtp, dflash, eagle, off"
        },
        "max_context": {
          "type": "integer"
        },
        "gpu_layers": {
          "type": "integer"
        },
        "mtp_enabled": {
          "type": "boolean"
        },
        "speculative_n": {
          "type": "integer"
        },
        "server_version": {
          "type": "string"
        },
        "build_info": {
          "type": "string"
        },
        "sampling_defaults": {
          "type": "object",
          "properties": {
            "temperature": {
              "type": "number"
            },
            "top_p": {
              "type": "number"
            },
            "top_k": {
              "type": "integer"
            },
            "repeat_penalty": {
              "type": "number"
            }
          }
        },
        "platform_raw": {
          "type": "object",
          "additionalProperties": true,
          "description": "Full server response for grep-ability"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "integer", "string", "boolean", "null", "array", "object"]
      },
      "properties": {
        "fizeau_version": {
          "type": "string"
        },
        "fizeau_git_commit": {
          "type": "string"
        },
        "harness_wrapper_name": {
          "type": "string"
        },
        "harness_wrapper_version": {
          "type": "string"
        },
        "harness_cli_version": {
          "type": "string"
        },
        "harness_runtime_version": {
          "type": "string"
        },
        "provider_endpoint": {
          "type": "string"
        },
        "provider_surface": {
          "type": "string"
        },
        "provider_version": {
          "type": "string"
        },
        "provider_capture_at": {
          "type": "string",
          "format": "date-time"
        },
        "model_snapshot": {
          "type": "string"
        },
        "model_version": {
          "type": "string"
        },
        "model_artifact_path": {
          "type": "string"
        },
        "model_artifact_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "session_log_path": {
          "type": "string"
        },
        "session_log_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "trajectory_path": {
          "type": "string"
        },
        "trajectory_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "benchmark_subset": {
          "type": "string"
        },
        "benchmark_subset_version": {
          "type": "string"
        },
        "benchmark_runner_version": {
          "type": "string"
        }
      }
    }
  }
}
