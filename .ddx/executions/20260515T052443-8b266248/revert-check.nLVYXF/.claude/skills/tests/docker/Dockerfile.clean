# Dockerfile for clean machine installation test
# This image starts minimal and tests the install.sh script

FROM ubuntu:24.04

# Prevent interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Install basic dependencies (no ddx, no go)
RUN apt-get update && apt-get install -y \
    curl \
    git \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Create test user
RUN useradd -m -s /bin/bash tester

USER tester
WORKDIR /home/tester

# This is the test surface:
# - Run install.sh
# - Verify ddx binary exists in PATH
# - Verify ~/.ddx/ structure
# - Verify skills are installed
