{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ddx.dev/schemas/bead-record.schema.json",
  "title": "DDx Bead Record",
  "description": "Base bead-schema record used for DDx bead-backed collections. Unknown fields are allowed for compatibility with bd/br exports and DDx domain-specific extensions.",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "priority",
    "issue_type",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["open", "in_progress", "closed"]
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "issue_type": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "parent": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "acceptance": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_id", "depends_on_id", "type"],
        "properties": {
          "issue_id": {
            "type": "string",
            "minLength": 1
          },
          "depends_on_id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "created_by": {
            "type": "string"
          },
          "metadata": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
