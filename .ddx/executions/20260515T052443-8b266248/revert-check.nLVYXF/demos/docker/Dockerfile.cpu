# syntax=docker/dockerfile:1.6
#
# demos/docker/Dockerfile.cpu — reproducible CPU-only environment for
# capturing Fizeau demo reels.
#
# Layers:
#   1. golang:1.23 build stage compiles `fiz` from the repo (statically linked).
#   2. ghcr.io/ggml-org/llama.cpp:server  — upstream prebuilt llama-server
#      (server-only image; no CUDA, no compile cost in our layer).
#   3. Final stage: ubuntu:24.04 + fiz + llama-server binaries +
#      Qwen2.5-Coder-0.5B-Instruct.Q4_K_M.gguf (~390 MB) baked in.
#
# Model choice rationale:
#   - Qwen2.5-Coder-0.5B-Instruct.Q4_K_M  → ~390 MB on disk, ~700 MB RSS at
#     ctx=4096. Smallest Qwen-Coder family member that reliably emits valid
#     JSON tool calls for the trivial "list go files" / "read this file"
#     style prompts the demos actually need.
#   - First-boot RAM: ~900 MB (model + llama-server overhead). Runs on a
#     2 vCPU / 2 GB GitHub-hosted runner.
#
# Multi-arch: built with `docker buildx build --platform linux/amd64,linux/arm64`.
# llama.cpp upstream ships both arches; the ubuntu base supports both.

ARG LLAMA_TAG=b6892
ARG MODEL_URL=https://huggingface.co/Qwen/Qwen2.5-Coder-0.5B-Instruct-GGUF/resolve/main/qwen2.5-coder-0.5b-instruct-q4_k_m.gguf
ARG MODEL_SHA256=

# ---------------------------------------------------------------------------
# Stage 1 — compile fiz
# ---------------------------------------------------------------------------
FROM --platform=$BUILDPLATFORM golang:1.23-bookworm AS fiz-build
WORKDIR /src
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    go mod download
COPY . .
ARG TARGETOS
ARG TARGETARCH
ENV CGO_ENABLED=0
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build -trimpath -ldflags="-s -w" -o /out/fiz ./cmd/fiz

# ---------------------------------------------------------------------------
# Stage 2 — upstream llama.cpp server image (prebuilt, multi-arch)
# ---------------------------------------------------------------------------
FROM ghcr.io/ggml-org/llama.cpp:server AS llama

# ---------------------------------------------------------------------------
# Stage 3 — runtime
# ---------------------------------------------------------------------------
FROM ubuntu:24.04

ARG MODEL_URL
ARG MODEL_SHA256

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl jq tini libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# fiz binary
COPY --from=fiz-build /out/fiz /usr/local/bin/fiz

# llama-server (and shared libs) from upstream image. The upstream image
# installs the server at /app/llama-server with shared libs alongside.
COPY --from=llama /app /opt/llama
RUN ln -s /opt/llama/llama-server /usr/local/bin/llama-server \
    && ldconfig /opt/llama

# Pull the model at build-time so the image is self-contained (no runtime
# download — one of the goals of the Docker-ified pipeline).
RUN mkdir -p /models \
 && curl -fsSL --retry 3 -o /models/model.gguf "$MODEL_URL" \
 && if [ -n "$MODEL_SHA256" ]; then \
        echo "$MODEL_SHA256  /models/model.gguf" | sha256sum -c -; \
    fi \
 && ls -lh /models/model.gguf

# Demo workspace + fizeau config that points at the local llama-server.
RUN mkdir -p /work /root/.fizeau
COPY demos/docker/fizeau-config.yaml /root/.fizeau/config.yaml
COPY demos/docker/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENV FIZ_DEMO_MODEL=/models/model.gguf \
    FIZ_DEMO_CTX=4096 \
    LLAMA_PORT=8080

EXPOSE 8080
WORKDIR /work
ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/entrypoint.sh"]
CMD ["bash"]
