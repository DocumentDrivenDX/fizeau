# Evidence-grade Terminal-Bench comparison config.
#
# Usage:
#   1. Build a linux/amd64 fizeau binary from either pinned SHA below.
#   2. export FIZEAU_BENCH_BINARY=/abs/path/to/fiz-linux-amd64
#   3. export FIZEAU_BENCH_SHA="$DDX_BENCH_BEFORE_SHA"   # or AFTER
#   4. set OPENROUTER_API_KEY in the shell
#   5. source ./scripts/benchmark/evidence-grade-comparison.env
#   6. ./scripts/benchmark/run_benchmark.sh
#
# This file pins the shared comparison controls. The only intended per-run
# variation is FIZEAU_BENCH_BINARY and FIZEAU_BENCH_SHA.

export DDX_BENCH_BEFORE_SHA=9c8b5b09fb4058545201b8d72a21b0861e4a4cdb
export DDX_BENCH_AFTER_SHA=dcc2f4512207e8b80d9f70bb2aeb7cb6c3913077

export DDX_BENCH_DATASET=terminal-bench@2.0
export DDX_BENCH_SUBSET_FILE=./scripts/benchmark/task-subset-v2.yaml
export DDX_BENCH_RUNTIME=docker
export DDX_BENCH_PRESET=benchmark

export DDX_BENCH_PROVIDER_NAME=openrouter
export DDX_BENCH_PROVIDER_TYPE=lmstudio
export DDX_BENCH_PROVIDER_MODEL=qwen/qwen3.6-plus
export DDX_BENCH_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
export DDX_BENCH_PROVIDER_API_KEY_ENV=OPENROUTER_API_KEY
export DDX_BENCH_PROVIDER_HEADERS_JSON=

# Keep blank unless the comparison protocol is explicitly amended.
export DDX_BENCH_SYSTEM_APPEND=
