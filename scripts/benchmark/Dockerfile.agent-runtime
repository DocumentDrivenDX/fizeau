FROM debian:bookworm-slim

ARG TARGETARCH
ARG NODE_VERSION=20.19.2
ARG CLAUDE_CODE_VERSION
ARG CODEX_VERSION
ARG PI_VERSION=0.67.1
ARG OPENCODE_VERSION=1.3.17

RUN apt-get update \
  && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    gzip \
    tar \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /runtime-input

COPY fiz /installed-agent/fiz

RUN set -eux; \
  chmod 755 /installed-agent/fiz; \
  case "${TARGETARCH}" in \
    amd64) node_arch="x64" ;; \
    arm64) node_arch="arm64" ;; \
    *) echo "unsupported TARGETARCH=${TARGETARCH}" >&2; exit 1 ;; \
  esac; \
  curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${node_arch}.tar.gz" -o /runtime-input/node.tgz; \
  tar -xzf /runtime-input/node.tgz -C /installed-agent; \
  mv /installed-agent/node-v* /installed-agent/node; \
  ln -sf /installed-agent/node/bin/node /usr/local/bin/node; \
  export PATH=/installed-agent/node/bin:$PATH; \
  claude_pkg="@anthropic-ai/claude-code"; \
  codex_pkg="@openai/codex"; \
  pi_pkg="@mariozechner/pi-coding-agent"; \
  opencode_pkg="opencode-ai"; \
  if [ -n "${CLAUDE_CODE_VERSION}" ]; then claude_pkg="${claude_pkg}@${CLAUDE_CODE_VERSION}"; fi; \
  if [ -n "${CODEX_VERSION}" ]; then codex_pkg="${codex_pkg}@${CODEX_VERSION}"; fi; \
  if [ -n "${PI_VERSION}" ]; then pi_pkg="${pi_pkg}@${PI_VERSION}"; fi; \
  if [ -n "${OPENCODE_VERSION}" ]; then opencode_pkg="${opencode_pkg}@${OPENCODE_VERSION}"; fi; \
  /installed-agent/node/bin/npm install -g "${claude_pkg}" "${codex_pkg}" "${pi_pkg}" "${opencode_pkg}"; \
  printf '%s\n' '#!/bin/sh' 'exec /installed-agent/node/lib/node_modules/@anthropic-ai/claude-code/bin/claude.exe "$@"' > /installed-agent/claude; \
  printf '%s\n' '#!/bin/sh' 'exec /installed-agent/node/bin/node /installed-agent/node/lib/node_modules/@openai/codex/bin/codex.js "$@"' > /installed-agent/codex; \
  printf '%s\n' '#!/bin/sh' 'exec /installed-agent/node/bin/node /installed-agent/node/lib/node_modules/@mariozechner/pi-coding-agent/dist/cli.js "$@"' > /installed-agent/pi; \
  printf '%s\n' '#!/bin/sh' 'exec /installed-agent/node/bin/opencode "$@"' > /installed-agent/opencode; \
  chmod 755 /installed-agent/claude /installed-agent/codex /installed-agent/pi /installed-agent/opencode /installed-agent/node/lib/node_modules/@mariozechner/pi-coding-agent/dist/cli.js
