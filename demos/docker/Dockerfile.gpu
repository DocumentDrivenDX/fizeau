# syntax=docker/dockerfile:1.6
#
# demos/docker/Dockerfile.gpu — CUDA variant of the demo capture image.
# Uses the upstream CUDA-enabled llama.cpp server build; otherwise identical
# to Dockerfile.cpu. Intended for capturing the heavier "real LLM" reels
# (qwen3-7B class) without the OpenRouter dependency.
#
# Build:
#   docker build -f demos/docker/Dockerfile.gpu -t fiz-demos-gpu .
# Run:
#   docker run --gpus all --rm -it -v $(pwd)/demos/sessions:/out fiz-demos-gpu
#
# This image deliberately does NOT bake a model — pull at runtime via a
# bind mount or `wget` so the same image works for many model sizes.

ARG MODEL_DIR=/models

FROM --platform=$BUILDPLATFORM golang:1.23-bookworm AS fiz-build
WORKDIR /src
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    go mod download
COPY . .
ARG TARGETOS
ARG TARGETARCH
ENV CGO_ENABLED=0
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build -trimpath -ldflags="-s -w" -o /out/fiz ./cmd/fiz

# Upstream CUDA server image (multi-arch where available; CUDA = amd64 only).
FROM ghcr.io/ggml-org/llama.cpp:server-cuda AS llama

FROM nvidia/cuda:12.4.1-runtime-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl jq tini libgomp1 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=fiz-build /out/fiz /usr/local/bin/fiz
COPY --from=llama /app /opt/llama
RUN ln -s /opt/llama/llama-server /usr/local/bin/llama-server \
    && ldconfig /opt/llama

RUN mkdir -p /work /models /root/.fizeau
COPY demos/docker/fizeau-config.yaml /root/.fizeau/config.yaml
COPY demos/docker/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENV FIZ_DEMO_MODEL=/models/model.gguf \
    FIZ_DEMO_CTX=8192 \
    LLAMA_PORT=8080 \
    LLAMA_NGL=999

EXPOSE 8080
WORKDIR /work
ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/entrypoint.sh"]
CMD ["bash"]
