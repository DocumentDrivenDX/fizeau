# Dockerfile for testing missing ddx binary scenario
# Used for AC-004

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    curl \
    git \
    jq \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash tester

USER tester
WORKDIR /home/tester

# Install ddx skills but NOT the binary
# This simulates a broken/missing ddx while skills are present
RUN mkdir -p /home/tester/.ddx/skills && \
    mkdir -p /home/tester/.agents/skills && \
    mkdir -p /home/tester/.claude/skills

# Copy bootstrap skills (would be done by ddx init in real scenario)
# For this test, we just verify that skills exist without binary
